{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MYKO",
  "version": "0.1.0",
  "identifier": "com.myko.dashboard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MYKO",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "alwaysOnTop": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' http://127.0.0.1:9473 ipc: http://ipc.localhost; img-src 'self' data: blob:; font-src 'self' data:",
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "MYKO — Sovereign Life OS",
    "longDescription": "Local-first, decentralized Life OS with encrypted IPFS vault, Nostr identity, and Lightning payments."
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false,
      "scope": {
        "allow": ["$HOME/MYKO/.session_token"]
      }
    }
  }
}
